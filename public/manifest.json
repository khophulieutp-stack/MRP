{
  "manifest_version": 3,
  "name": "LỆNH CẤP PHÁT",
  "version": "4.10.9.5",
  "description": "Hoạch định nhu cầu vật tư và tạo lệnh xuất kho thông minh.",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://172.20.0.5:8080/*",
        "file:///*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": [
    "http://172.20.0.5:8080/*",
    "file:///*"
  ],
  "action": {
    "default_title": "Mở ứng dụng Lệnh Cấp Phát"
  },
  "background": {
    "service_worker": "background.js"
  }
}
